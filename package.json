{
  "name": "BeneStats",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write \"src/**/*.{ts,tsx,js,jsx,json,css,md}\"",
    "format:check": "prettier --check \"src/**/*.{ts,tsx,js,jsx,json,css,md}\"",
    "preview": "vite preview",
    "prepare": "husky",
    "type-check": "tsc --noEmit",
    "test": "vitest run tests/store tests/services tests/hooks tests/utils",
    "test:all": "vitest run",
    "test:pages": "vitest run tests/pages",
    "test:components": "vitest run tests/components",
    "test:ui": "vitest run tests/pages/SignInPage.test.tsx && vitest run tests/pages/RegisterPage.test.tsx && vitest run tests/pages/DashboardPage.test.tsx && vitest run tests/pages/VerifyEmailPage.test.tsx && vitest run tests/components/assessment/WorkforceTab.test.tsx && vitest run tests/components/assessment/CompensationTab.test.tsx && vitest run tests/components/assessment/BenefitsTab.test.tsx && vitest run tests/components/assessment/GoalsTab.test.tsx",
    "test:watch": "vitest --watch",
    "test:coverage": "vitest run tests/store tests/services tests/hooks tests/utils tests/pages tests/components --coverage"
  },
  "lint-staged": {
    "*.{ts,tsx}": [
      "eslint --fix",
      "prettier --write"
    ],
    "*.{json,css,md}": [
      "prettier --write"
    ]
  },
  "dependencies": {
    "@dnd-kit/core": "^6.3.1",
    "@dnd-kit/sortable": "^10.0.0",
    "@dnd-kit/utilities": "^3.2.2",
    "@hookform/resolvers": "^5.2.2",
    "@react-stately/utils": "^3.11.0",
    "@react-types/overlays": "^3.9.2",
    "@react-types/shared": "^3.32.1",
    "@reduxjs/toolkit": "^2.11.2",
    "@tailwindcss/typography": "^0.5.19",
    "@tailwindcss/vite": "^4.1.18",
    "@tryfinch/react-connect": "^5.0.1",
    "@untitledui/icons": "^0.0.22",
    "axios": "1.13.2",
    "embla-carousel-react": "^8.6.0",
    "react": "^19.2.0",
    "react-aria": "^3.45.0",
    "react-aria-components": "^1.17.0",
    "react-dom": "^19.2.0",
    "react-hook-form": "^7.71.1",
    "react-loader-spinner": "^8.0.2",
    "react-redux": "^9.2.0",
    "react-router-dom": "^7.12.0",
    "react-stately": "^3.43.0",
    "recharts": "^3.7.0",
    "tailwind-merge": "^3.5.0",
    "tailwindcss": "^4.1.18",
    "tailwindcss-animate": "^1.0.7",
    "tailwindcss-react-aria-components": "^2.0.1",
    "zod": "^4.3.5"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.2",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/node": "^24.10.1",
    "@types/react": "^19.2.5",
    "@types/react-dom": "^19.2.3",
    "@typescript-eslint/eslint-plugin": "^8.53.0",
    "@typescript-eslint/parser": "^8.53.0",
    "@vitejs/plugin-react": "^5.1.1",
    "@vitest/coverage-v8": "^4.1.5",
    "@vitest/ui": "^4.0.18",
    "eslint": "^9.39.2",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-prettier": "^5.5.5",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.4.26",
    "globals": "^16.5.0",
    "husky": "^9.1.7",
    "jsdom": "^28.1.0",
    "lint-staged": "^16.2.7",
    "prettier": "^3.8.0",
    "typescript": "~5.9.3",
    "typescript-eslint": "^8.53.0",
    "vite": "npm:rolldown-vite@7.2.5",
    "vitest": "^4.0.18"
  },
  "overrides": {
    "vite": "npm:rolldown-vite@7.2.5",
    "cssstyle": "4.2.1"
  },
  "pnpm": {
    "overrides": {
      "cssstyle": "4.2.1"
    }
  }
}
